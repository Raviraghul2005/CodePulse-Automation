# ====================================================================
# Coding Consistency Tracker Configuration Template
# Rename this file to ".env" and fill in your details.
# ====================================================================

# The Gmail address you want to send the daily emails FROM
EMAIL_ADDRESS=your_email@gmail.com

# Your Gmail App Password (NOT your normal email password!)
# Learn how to create one here: https://support.google.com/accounts/answer/185833
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# The email address you want to send the daily emails TO
# (Can be the same as EMAIL_ADDRESS if you want to email yourself)
RECEIVER_EMAIL=your_email@gmail.com

# GitHub username to track activity for
GITHUB_USERNAME=your_github_username

# LeetCode username to track activity for
LEETCODE_USERNAME=your_leetcode_username
